{
  "name": "slo-operator-api-5xx-rate",
  "description": "Alert when operator API 5xx exceeds 1.0% over 5 minutes.",
  "type": "scheduledQuery",
  "severity": 2,
  "evaluationFrequency": "PT5M",
  "windowSize": "PT5M",
  "queryFile": "../kql/operator_api_5xx_budget.kql",
  "condition": {
    "metricColumn": "five_xx_pct",
    "operator": "GreaterThan",
    "threshold": 1.0
  }
}
