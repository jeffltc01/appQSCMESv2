{
  "name": "frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:tier1": "npm run test -- src/components/layout/TopBar.test.tsx src/features/admin/DowntimeEventsScreen.test.tsx src/features/admin/ProductionLineWorkCentersScreen.test.tsx && npm run typecheck",
    "verify:tier2": "npm run ci:verify",
    "ci:verify": "npm run build && npm run test:coverage",
    "build:help-pdf": "node scripts/build-help-pdf.mjs"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.54",
    "@types/jsbarcode": "^3.11.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "md-to-pdf": "^5.2.5",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.0",
    "@fluentui/react-icons": "^2.0.319",
    "dagre": "^0.8.5",
    "jsbarcode": "^3.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1"
  }
}
